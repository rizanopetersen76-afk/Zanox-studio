<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zanox Studios</title>
<link rel="stylesheet" href="style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
</head>
<body>

<header>
  <nav>
    <h1>Zanox Studios</h1>
    <ul>
      <li><a href="#services">Services</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>
</header>

<section class="hero">
  <div class="hero-text animate__animated animate__fadeInDown">
    <h2>Modern Digital Solutions</h2>
    <p>Graphic Design • Web Development • Social Media Management</p>
    <a href="#contact" class="btn">Get Started</a>
  </div>
</section>

<section id="services">
  <h2 class="section-title">Our Services</h2>
  <div class="services-grid">
    <div class="card animate__animated animate__fadeInUp">
      <h3>Graphic Design</h3>
      <p>Logos, branding, posters, and visual identity for modern businesses.</p>
    </div>
    <div class="card animate__animated animate__fadeInUp" style="animation-delay:0.2s;">
      <h3>Website Development</h3>
      <p>Professional websites that attract customers and grow your business.</p>
    </div>
    <div class="card animate__animated animate__fadeInUp" style="animation-delay:0.4s;">
      <h3>Social Media Management</h3>
      <p>We manage your online presence and help your brand reach more people.</p>
    </div>
  </div>
</section>

<section id="contact">
  <h2 class="section-title">Contact Us</h2>
  <p>Ready to grow your business online?</p>
  <!-- WhatsApp button -->
  <a href="https://wa.me/27817694899" target="_blank" class="btn whatsapp">Message Us on WhatsApp</a>
  <!-- Email -->
  <p style="margin-top:15px;">Or email us at: <a href="mailto:info@zanoxstudio.co.za">info@zanoxstudio.co.za</a></p>
</section>

<footer>
  <p>&copy; 2026 Zanox Studios. All rights reserved.</p>
</footer>

<script src="script.js"></script>
</body>
</html>
/* General */
body {
  font-family: 'Arial', sans-serif;
  margin:0;
  padding:0;
  background:#0f172a;
  color:white;
}

a {
  text-decoration:none;
  color:white;
}

header {
  background:#020617;
  padding:20px 40px;
}

header nav {
  display:flex;
  justify-content:space-between;
  align-items:center;
}

header nav ul {
  display:flex;
  list-style:none;
  gap:20px;
}

header nav ul li a:hover {
  color:#3b82f6;
}

/* Hero */
.hero {
  text-align:center;
  padding:120px 20px;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
}

.hero .btn {
  background:#3b82f6;
  padding:15px 30px;
  border-radius:8px;
  display:inline-block;
  margin-top:20px;
  font-weight:bold;
}

.hero .btn:hover {
  background:#2563eb;
}

/* Sections */
.section-title {
  text-align:center;
  font-size:2em;
  margin-bottom:40px;
}

.services-grid {
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:30px;
  padding:0 20px 60px;
}

.card {
  background:#1e293b;
  padding:30px;
  border-radius:12px;
  width:250px;
  text-align:center;
  transition:transform 0.3s, box-shadow 0.3s;
}

.card:hover {
  transform:translateY(-10px);
  box-shadow:0 10px 20px rgba(0,0,0,0.5);
}

/* Contact */
#contact {
  text-align:center;
  padding:80px 20px;
}

#contact .btn.whatsapp {
  background:#25d366;
}

#contact .btn.whatsapp:hover {
  background:#1ebe5b;
}

/* Footer */
footer {
  text-align:center;
  padding:30px;
  background:#020617;
  font-size:0.9em;
  color:#888;
}

/* Responsive */
@media(max-width:768px){
  .services-grid {
    flex-direction:column;
    align-items:center;
  }

  header nav ul {
    flex-direction:column;
    gap:10px;
  }
}
